{
	"name": "basalt",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^6",
			"@types/bun": "^1.3.4",
			"hono": "^4.8.2",
			"@orpc/server": "^1.13.14",
			"@orpc/openapi": "^1.13.14",
			"@orpc/zod": "^1.13.14",
			"better-auth": "1.5.5",
			"@orpc/client": "^1.13.14"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev db:studio",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @basalt/db db:push",
		"db:studio": "turbo -F @basalt/db db:studio",
		"db:generate": "turbo -F @basalt/db db:generate",
		"db:migrate": "turbo -F @basalt/db db:migrate",
		"db:start": "turbo -F @basalt/db db:start",
		"db:watch": "turbo -F @basalt/db db:watch",
		"db:stop": "turbo -F @basalt/db db:stop",
		"db:down": "turbo -F @basalt/db db:down",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@basalt/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@basalt/config": "workspace:*",
		"@biomejs/biome": "^2.2.0",
		"@types/bun": "catalog:",
		"turbo": "^2.8.12",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.8"
}
